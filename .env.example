# .env.example — modèle de configuration locale.
#
# Copiez ce fichier en ".env" et renseignez vos propres valeurs :
#     cp .env.example .env
#
# Le fichier .env contient des SECRETS : il est ignoré par git (.gitignore)
# et ne doit JAMAIS être committé. Ce modèle-ci, lui, est public et vide.

# --- Alertes Slack (facultatif) ---
# Créez un "Incoming Webhook" sur https://api.slack.com/apps, choisissez le
# canal de destination, puis collez l'URL ci-dessous. Laissez vide pour
# désactiver les alertes (le WAF fonctionne sans).
SENTINEL_SLACK_WEBHOOK=

# Webhook Discord (facultatif) — configurable aussi depuis le dashboard.
# Salon Discord → Paramètres → Intégrations → Webhooks → Nouveau webhook.
SENTINEL_DISCORD_WEBHOOK=

# Fenêtre d'agrégation des alertes, en secondes (anti-spam). Défaut : 15.
SENTINEL_ALERT_INTERVAL_SEC=15

# --- Authentification admin (recommandé) ---
# Définit le mot de passe de la console. Tant qu'il est vide, le dashboard est
# OUVERT (aucune connexion requise). Renseignez-le pour verrouiller l'accès :
# seul son hachage est stocké, jamais le mot de passe en clair.
SENTINEL_ADMIN_PASSWORD=

# --- Enrichissement IA des alertes (facultatif) ---
# Analyse des attaques en langage naturel via une API compatible OpenAI
# (RodiumAI, Groq, OpenAI, Ollama…). Laisser LLM_ENABLED vide pour désactiver.
# La clé est un SECRET : ne jamais la versionner (garder dans .env, gitignoré).
LLM_ENABLED=
LLM_BASE_URL=https://api.rodiumai.io/v1
LLM_API_KEY=
LLM_MODEL=meta/llama-3.3-70b-instruct

# --- Rétention des événements (facultatif) ---
# Le plus strict des deux s'applique. 0 = illimité. Défauts : 30 jours / 100000.
SENTINEL_RETENTION_DAYS=30
SENTINEL_RETENTION_MAX=100000

# --- Ports d'accès (facultatif) ---
# Port de la passerelle WAF (proxy) et de la console d'administration.
SENTINEL_HTTP_PORT=8000
SENTINEL_DASHBOARD_PORT=3000

# Mot de passe de la base PostgreSQL (interne). Changez-le en production.
POSTGRES_PASSWORD=change_me
